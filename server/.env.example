# Database
DATABASE_URL=postgresql://user:password@localhost:5432/gan_halomot

# Auth
JWT_SECRET=your-jwt-secret-here

# Email (Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Cloudflare R2 (S3-compatible)
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_BUCKET=gan-halomot-files
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Google Sheets Migration (one-time only)
GOOGLE_SHEETS_ID=1H-pCIZQEIm6aXYfgZt_ZU6LXn6rUIfh7t1j6N0adpy0
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./google-sa-key.json

# Server
PORT=3001
NODE_ENV=development
