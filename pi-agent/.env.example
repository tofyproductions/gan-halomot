# -----------------------------------------------------------------------------
# Pi Agent configuration — per branch. Copy this file to `.env` on the Pi
# and fill in the real values (never commit `.env`).
# -----------------------------------------------------------------------------

# Identity of this branch in the gan-halomot server (MongoDB ObjectId).
BRANCH_ID=

# Shared secret for this branch (printed by `scripts/seed-attendance.js`).
AGENT_SECRET=

# TIMEDOX clock connection
CLOCK_IP=10.0.0.3
CLOCK_PORT=4370
CLOCK_TIMEOUT_MS=10000
CLOCK_INPORT=5200

# Server URL (production) — include protocol, no trailing slash
SERVER_URL=https://gan-halomot.onrender.com

# Polling intervals (milliseconds)
POLL_PUNCHES_MS=15000
POLL_COMMANDS_MS=30000
POLL_HEARTBEAT_MS=60000

# Networking
HTTP_TIMEOUT_MS=15000
HTTP_RETRY_MAX=5
HTTP_RETRY_BASE_MS=2000

# Where the agent keeps its local state (last_user_sn, last successful poll, etc.)
STATE_FILE=./state.json

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Optional: if set, agent uses device-reported timestamps. We leave this false
# by default because node-zklib returns 1999-12-31 for historical records on
# TANDEM4 PRO firmware. Fresh punches detected via polling are timestamped at
# the moment the Pi receives them (close to wall-clock true time via NTP).
TRUST_DEVICE_TIMESTAMPS=false
