{
  "name": "gan-halomot",
  "version": "1.0.0",
  "private": true,
  "description": "Gan HaHalomot - Kindergarten Management System",
  "scripts": {
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",
    "build": "cd client && npm install && npm run build",
    "migrate": "cd server && npx knex migrate:latest",
    "seed": "cd server && npx knex seed:run",
    "import": "cd server && node scripts/import-from-gsheets.js",
    "vercel-build": "cd client && npm install && npm run build"
  },
  "dependencies": {
    "express": "^4.21.0",
    "knex": "^3.1.0",
    "pg": "^8.13.0",
    "dotenv": "^16.4.5",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.23.8",
    "nodemailer": "^6.9.15",
    "@aws-sdk/client-s3": "^3.665.0",
    "@aws-sdk/s3-request-presigner": "^3.665.0",
    "multer": "^1.4.5-lts.1",
    "helmet": "^8.0.0",
    "cors": "^2.8.5",
    "morgan": "^1.10.0",
    "uuid": "^10.0.0"
  }
}
